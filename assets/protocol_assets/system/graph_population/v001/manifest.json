{
  "schema_version": "ortelius.system_protocol_manifest.v0",
  "system_protocol_id": "graph_population",
  "version": "v001",
  "protocol_kind": "system_graph_population_protocols",
  "domain_agnostic": true,
  "system_root": "assets/protocol_assets/system/graph_population/v001",
  "documents": {
    "protocol_schema": "graph_population_protocol_schema.md",
    "control_protocol": "graph_population_control_protocol.md",
    "readme": "README.md"
  },
  "prompts": {
    "generate_bundle": "prompts/generate_bundle.md",
    "execute_bundle": "prompts/execute_bundle.md"
  },
  "trigger_phrases": {
    "generate_bundle": "GENERATE-BUNDLE",
    "execute_bundle": "EXECUTE-BUNDLE",
    "make_graph": "MAKE-GRAPH"
  },
  "generated_bundle_contract": {
    "bundle_root_pattern": "assets/protocol_assets/bundles/<domain_slug>/<protocol_id>",
    "required_files": [
      "manifest.json",
      "graph_population_protocol.md",
      "runs/<run_id>/cursor.json",
      "runs/<run_id>/execution_log.md"
    ],
    "required_directories": [
      "loop_specs",
      "candidate_graphs",
      "runs/<run_id>"
    ],
    "required_manifest_fields": [
      "schema_version",
      "protocol_id",
      "domain",
      "graphs",
      "documents",
      "ordered_loop_specs",
      "runs",
      "run_contract_completeness"
    ],
    "required_loop_spec_headings": [
      "Loop Identity",
      "Inputs",
      "Iterator",
      "Current Item Shape",
      "Action Template",
      "Allowed Writes",
      "Source Boundaries",
      "Evidence Required",
      "Validation Required",
      "Completion Rule",
      "Semantic Acceptance Gate",
      "Recovery Policy",
      "Batch Execution",
      "Stop Conditions",
      "Handoff"
    ],
    "required_make_graph_artifacts": [
      "control_loop_plan.md",
      "runs/<run_id>/reports/generated_bundle_acceptance_report.md",
      "runs/<run_id>/reports/graph_intent_contract.md",
      "runs/<run_id>/reports/source_landscape_map.md",
      "runs/<run_id>/reports/source_family_registry.md",
      "runs/<run_id>/source_adapter_candidate_frontier.md",
      "runs/<run_id>/reports/source_strategy_decision_log.md",
      "runs/<run_id>/reports/joint_population_feasibility_plan.md",
      "runs/<run_id>/reports/endpoint_reservation_plan.md",
      "runs/<run_id>/reports/semantic_acceptance_report.md",
      "runs/<run_id>/reports/source_reconnaissance_plan.md",
      "runs/<run_id>/reports/source_adapter_recovery_plan.md",
      "runs/<run_id>/reports/generated_code_runtime_audit.md",
      "runs/<run_id>/reports/domain_membership_audit.md",
      "runs/<run_id>/reports/semantic_sample_audit.md"
    ],
    "semantic_acceptance_validator_checks": [
      "source_landscape_artifacts_present",
      "source_family_monoculture_rejected_without_exception",
      "placeholder_batch_packets_rejected",
      "generated_code_runtime_rejected",
      "domain_membership_predicates_required",
      "type_field_richness_required_beyond_source_adapter_fields",
      "joint_population_feasibility_required_before_completion",
      "graph_intent_contract_present",
      "graph_intent_alignment_loop_precedes_source_and_type_discovery",
      "graph_intent_downstream_gate_required",
      "semantic_acceptance_checks_graph_intent_fit",
      "graph_intent_contract_materialized_before_source_probe",
      "source_reconnaissance_plan_required_before_source_results",
      "source_result_requires_declared_batch_packet",
      "generated_code_runtime_audit_required",
      "candidate_records_never_count_toward_targets",
      "accepted_target_reconciliation_required",
      "semantic_sample_audit_required_before_completion",
      "domain_membership_audit_required_before_completion",
      "semantic_report_counter_contradictions_rejected",
      "completion_narration_must_match_semantic_status"
    ]
  },
  "graph_contract": {
    "default_type_graph_id_example": "tg",
    "default_fiber_graph_id_example": "fg",
    "candidate_graph_paths": {
      "type_nodes": "candidate_graphs/<type_graph_id>/nodes.json",
      "type_edges": "candidate_graphs/<type_graph_id>/edges.json",
      "fiber_nodes": "candidate_graphs/<fiber_graph_id>/nodes.json",
      "fiber_edges": "candidate_graphs/<fiber_graph_id>/edges.json"
    },
    "loader_shape": {
      "function": "load_graph_bundle",
      "required_arguments": [
        "graph_root",
        "type_graph_id",
        "fiber_graph_id"
      ]
    }
  },
  "graph_tool_commands": {
    "validate": "uv run ortelius validate --graph-root <candidate_graph_root> --type-graph-id <type_graph_id> --fiber-graph-id <fiber_graph_id> --mode bootstrap",
    "inspect": "uv run ortelius inspect --graph-root <candidate_graph_root> --type-graph-id <type_graph_id> --fiber-graph-id <fiber_graph_id>",
    "materialize_networkx": "uv run ortelius materialize networkx --graph-root <candidate_graph_root> --type-graph-id <type_graph_id> --fiber-graph-id <fiber_graph_id>",
    "materialize_pyg": "uv run ortelius materialize pyg --graph-root <candidate_graph_root> --type-graph-id <type_graph_id> --fiber-graph-id <fiber_graph_id>",
    "materialize_dgl": "uv run ortelius materialize dgl --graph-root <candidate_graph_root> --type-graph-id <type_graph_id> --fiber-graph-id <fiber_graph_id>"
  },
  "non_goals": [
    "accepted_fact_writes",
    "hard_codex_api_interpreter",
    "system_directory_contains_domain_facts"
  ]
}
